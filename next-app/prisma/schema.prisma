generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Campaign {
  id String @id // campaign_id (field)

  creatorAddress String

  name        String
  description String?

  merkleRoot String
  depth      Int    @default(10)

  asset       Int
  totalBudget BigInt

  totalRecipients Int

  // aggregate stats only
  claimedCount  Int    @default(0)
  claimedAmount BigInt @default(0)

  poolAmount BigInt @default(0)

  creationTxHash String?
  fundingTxHash  String?

  createdAt DateTime  @default(now())
  expiry    DateTime?

  proofs     MerkleProofStore[]
  nullifiers ClaimNullifier[]

  escrow CampaignEscrow?

  status CampaignStatus

  @@index([creatorAddress])
}

model CreatorProfile {
  id String @id @default(cuid())

  walletAddress String @unique
  isProUser     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([walletAddress])
}

model MerkleProofStore {
  // hash(address + campaignId + salt)
  lookupHash String @id

  campaignId String

  payout BigInt

  proofData Json

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
}

model ClaimNullifier {
  nullifier String @id

  campaignId String

  claimedAt DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id])

  @@index([campaignId])
}

model CampaignEscrow {
  id String @id @default(cuid())

  campaignId String @unique

  recordCiphertext String
  recordPlaintext  String

  amount BigInt

  createdAt DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model PaymentLink {
  id String @id @default(cuid())

  creatorAddress String? // wallet-based
  telegramId     String? // bot-based

  requestId String @unique

  title       String
  description String?
  template    PaymentLinkTemplate @default(CUSTOM)
  successMessage String?
  redirectUrl String?
  suggestedAmounts Json?

  amount Decimal?
  token  Token

  allowCustomAmount Boolean @default(false)

  maxPayments      Int?
  paymentsReceived Int  @default(0)

  expiresAt DateTime?

  active Boolean @default(true)

  views          Int     @default(0)
  uniqueVisitors Int     @default(0)
  totalVolume    Decimal @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  telegramChatId    String?
  telegramMessageId String?
  createdViaBot     Boolean @default(false)

  visits            PaymentLinkVisit[]
  payments          Payment[]
  webhookDeliveries WebhookDelivery[]
}

model WebhookEndpoint {
  id String @id @default(cuid())

  creatorAddress String
  url            String
  secret         String?
  active         Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deliveries WebhookDelivery[]

  @@index([creatorAddress])
  @@unique([creatorAddress, url])
}

model PaymentLinkVisit {
  id        String   @id @default(cuid())
  linkId    String
  ipHash    String?
  userAgent String?
  country   String?
  createdAt DateTime @default(now())

  PaymentLink PaymentLink @relation(fields: [linkId], references: [id])

  @@index([linkId])
}

model Payment {
  id     String @id @default(cuid())
  linkId String

  payer        String?
  payerAddress String? // wallet
  telegramId   String? // bot user (if exists)
  merchantAddress String?

  amount Decimal
  token  Token
  txHash String? @unique
  receiptCommitment String?
  receiptOwner      String?

  status PaymentStatus @default(PENDING)

  createdAt DateTime @default(now())

  PaymentLink               PaymentLink                @relation(fields: [linkId], references: [id])
  telegramUser              TelegramUser?              @relation(fields: [telegramId], references: [telegramId])
  selectiveDisclosureProofs SelectiveDisclosureProof[]

  @@index([linkId])
  @@index([telegramId])
}

model SelectiveDisclosureProof {
  id String @id @default(cuid())

  proofId String @unique

  paymentId String

  paymentTxHash  String
  disclosureTxHash String?
  requestId      String
  creatorAddress String
  proverAddress  String
  ownerAddress   String
  commitment     String
  nullifier      String?
  contractProgram String

  constraints Json
  proofPayload Json?

  status    SelectiveDisclosureProofStatus @default(ACTIVE)
  createdAt DateTime                       @default(now())
  updatedAt DateTime                       @updatedAt
  revokedAt DateTime?

  payment       Payment                         @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  verifications SelectiveDisclosureVerification[]

  @@index([paymentId])
  @@index([paymentTxHash])
  @@index([disclosureTxHash])
  @@index([requestId])
  @@index([creatorAddress])
  @@index([proverAddress])
  @@index([status])
}

model SelectiveDisclosureVerification {
  id String @id @default(cuid())

  proofId String

  success Boolean
  revoked Boolean @default(false)

  verifier String?
  details  Json?

  createdAt DateTime @default(now())

  proof SelectiveDisclosureProof @relation(fields: [proofId], references: [proofId], onDelete: Cascade)

  @@index([proofId])
  @@index([createdAt])
}

model WebhookDelivery {
  id String @id @default(cuid())

  endpointId String
  linkId String

  eventType String
  targetUrl String
  payload   Json

  responseStatus Int?
  responseBody   String?
  success        Boolean @default(false)

  attemptedAt DateTime @default(now())

  endpoint    WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  paymentLink PaymentLink @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([endpointId])
  @@index([linkId])
  @@index([eventType])
}

model PayerStats {
  id String @id @default(cuid())

  // identity (either wallet or telegram)
  telegramId    String?
  walletAddress String?

  totalPaid     Decimal @default(0)
  totalPayments Int     @default(0)

  lastPaymentAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([telegramId])
  @@index([walletAddress])
}

model TransactionMetadata {
  id String @id @default(cuid())

  txHash String @unique

  explorerUrl String?

  createdAt DateTime @default(now())
}

model TelegramUser {
  id         String  @id @default(cuid())
  telegramId String  @unique
  username   String?
  firstName  String?
  lastName   String?

  // optional future wallet linking
  walletAddress String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  sessions TelegramSession[]
  payments Payment[]
}

model TelegramSession {
  id         String @id @default(cuid())
  telegramId String @unique

  step String

  // flexible JSON state
  data Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user TelegramUser @relation(fields: [telegramId], references: [telegramId])

  @@index([telegramId])
}

enum Token {
  ALEO
  USDCX
  USAD
}

enum PaymentLinkTemplate {
  INVOICE
  FREELANCE
  TIP_JAR
  CHECKOUT
  CUSTOM
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum CampaignStatus {
  PENDING
  CREATED
  FUNDED
}

enum SelectiveDisclosureProofStatus {
  ACTIVE
  REVOKED
}
